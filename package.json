{
	"name": "tomoribot",
	"version": "0.7.50",
	"description": "Customizable AI Assistant Discord Bot",
	"main": "./src/index.ts",
	"type": "module",
	"scripts": {
		"clean-dist": "bun run scripts/clean-dist.ts",
		"build": "bun run clean-dist && bun build ./src/index.ts --outdir dist --target bun",
		"start": "bun run dist/index.js",
		"dev": "bun --watch src/index.ts",
		"watch": "bun build ./src/index.ts --outdir dist --target node --watch",
		"purge-commands": "bun run scripts/purge-commands.ts",
		"seed-db": "bun run scripts/seed-db.ts",
		"nuke-db": "bun run scripts/nuke-db.ts",
		"backup-db": "bun run scripts/backup-db.ts",
		"migrate-nullable-user-id": "bun run scripts/migrate-nullable-user-id.ts",
		"delete-test-server": "bun run scripts/delete-test-server.ts",
		"lint": "bunx @biomejs/biome lint --fix",
		"check": "bunx tsc --noEmit",
		"check-locales": "bun run scripts/checkLocalizationKeys.ts",
		"check-limits": "bun run scripts/checkDiscordLimits.ts",
		"audit-keys": "bun run scripts/auditKeyVersions.ts",
		"rotate-keys": "bun run scripts/rotateAllKeys.ts",
		"check-keys": "bun run scripts/checkKeys.ts"
	},
	"author": "Bredrumb",
	"license": "ISC",
	"dependencies": {
		"@aws-sdk/client-secrets-manager": "^3.936.0",
		"@google/genai": "^1.30.0",
		"@modelcontextprotocol/sdk": "^1.22.0",
		"@openrouter/sdk": "^0.1.17",
		"@types/bun": "^1.3.2",
		"@types/dotenv": "^8.2.3",
		"@types/node": "^24.10.1",
		"@types/pg": "^8.15.6",
		"axios": "^1.13.2",
		"bing-translate-api": "^4.1.0",
		"bun-types": "^1.3.2",
		"discord.js": "14.25.0",
		"dotenv": "^17.2.3",
		"gifuct-js": "^2.1.2",
		"google-translate-api-x": "^10.7.2",
		"libsodium-wrappers": "^0.7.15",
		"pg": "^8.16.3",
		"sharp": "^0.34.5",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.6",
		"typescript": "^5.9.3"
	}
}
