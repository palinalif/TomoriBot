{
	"name": "tomoribot",
	"version": "0.7.890",
	"description": "Customizable AI Assistant Discord Bot",
	"main": "./src/index.ts",
	"type": "module",
	"scripts": {
		"clean-dist": "bun run scripts/cleanDist.ts",
		"build": "bun run clean-dist && bun build ./src/index.ts --outdir dist --target bun",
		"start": "bun run dist/index.js",
		"dev": "bun --watch src/index.ts",
		"watch": "bun build ./src/index.ts --outdir dist --target node --watch",
		"purge-commands": "bun run scripts/purgeCommands.ts",
		"seed-db": "bun run scripts/seedDb.ts",
		"nuke-db": "bun run scripts/nukeDb.ts",
		"backup-db": "bun run scripts/backupDb.ts",
		"cleanup-legacy-fallbacks": "bun run scripts/cleanupLegacyFallbacksV2.ts",
		"migrate-nullable-user-id": "bun run scripts/migrateNullableUserId.ts",
		"delete-test-server": "bun run scripts/deleteTestServer.ts",
		"lint": "bunx @biomejs/biome lint --fix",
		"check": "bunx tsc --noEmit",
		"check-locales": "bun run scripts/checkLocalizationKeys.ts",
		"check-limits": "bun run scripts/checkDiscordLimits.ts",
		"audit-keys": "bun run scripts/auditKeyVersions.ts",
		"rotate-keys": "bun run scripts/rotateAllKeys.ts",
		"check-keys": "bun run scripts/checkKeys.ts"
	},
	"author": "Bredrumb",
	"license": "ISC",
	"dependencies": {
		"@aws-sdk/client-s3": "^3.990.0",
		"@aws-sdk/client-secrets-manager": "^3.990.0",
		"@google/genai": "^1.41.0",
		"@hono/node-server": "^1.19.9",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"@openrouter/sdk": "^0.1.27",
		"@types/bun": "^1.3.9",
		"@types/dotenv": "^8.2.3",
		"@types/node": "^24.10.13",
		"@types/pg": "^8.16.0",
		"axios": "^1.13.5",
		"bing-translate-api": "^4.2.0",
		"bun-types": "^1.3.9",
		"discord.js": "14.25.0",
		"dotenv": "^17.3.1",
		"fast-xml-parser": "^5.4.1",
		"gifuct-js": "^2.1.2",
		"google-translate-api-x": "^10.7.2",
		"hono": "^4.12.2",
		"jszip": "^3.10.1",
		"libsodium-wrappers": "^0.7.16",
		"matrix-appservice-bridge": "^11.2.0",
		"minimatch": "^10.2.4",
		"pdf-parse": "^1.1.4",
		"pg": "^8.18.0",
		"pino": "^10.3.1",
		"profane-words": "^2.1.0",
		"sharp": "^0.34.5",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.15",
		"@types/jszip": "^3.4.1",
		"@types/pdf-parse": "^1.1.5",
		"pino-pretty": "^13.1.3",
		"typescript": "^5.9.3"
	},
	"overrides": {
		"body-parser": ">=2.2.1",
		"body-parser>qs": "6.14.2",
		"express>qs": "6.14.2",
		"jws": "^3.2.2",
		"lodash": "^4.17.23",
		"minimatch": ">=10.2.3",
		"qs": "6.14.2",
		"hono": "$hono",
		"undici": "^6.23.0",
		"fast-xml-parser": ">=5.3.8",
		"ajv": "^8.18.0",
		"form-data": ">=2.5.4",
		"underscore": ">=1.12.1",
		"nedb": "npm:@seald-io/nedb@latest",
		"tough-cookie": ">=4.1.3"
	},
	"patchedDependencies": {
		"@matrix-org/matrix-sdk-crypto-nodejs@0.4.0": "patches/@matrix-org%2Fmatrix-sdk-crypto-nodejs@0.4.0.patch"
	}
}
