{
  "name": "tomoribot",
  "version": "0.7.963",
  "description": "Customizable AI Assistant Discord Bot",
  "main": "./src/index.ts",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "dev": "bun --watch src/index.ts",
    "watch": "bun build ./src/index.ts --outdir dist --target node --watch",
    "purge-commands": "bun run scripts/maintenance/purgeCommands.ts",
    "nuke-db": "bun run scripts/maintenance/nukeDb.ts",
    "backup": "bun run scripts/maintenance/backupData.ts --backup",
    "restore-backup": "bun run scripts/maintenance/backupData.ts --restore",
    "backup:personas": "bun run scripts/maintenance/backupPersonas.ts",
    "backup:memories": "bun run scripts/maintenance/backupMemories.ts",
    "lint": "biome check --fix",
    "check": "bunx tsc --noEmit",
    "check-locales": "bun run scripts/maintenance/checkLocalizationKeys.ts",
    "check-schema": "bun run scripts/maintenance/checkSchemaDrift.ts",
    "list-unused-locales": "bun run scripts/maintenance/checkLocalizationKeys.ts --list-unused",
    "prune-locales": "bun run scripts/maintenance/pruneLocaleKeys.ts",
    "find-stale-translations": "bun run scripts/maintenance/findStaleTranslations.ts",
    "check-limits": "bun run scripts/maintenance/checkDiscordLimits.ts",
    "audit-keys": "bun run scripts/maintenance/auditKeyVersions.ts",
    "audit-legacy-provider-paths": "bun run scripts/maintenance/cleanupLegacyProviderArtifacts.ts",
    "cleanup-legacy-provider-paths": "bun run scripts/maintenance/cleanupLegacyProviderArtifacts.ts --apply",
    "rotate-keys": "bun run scripts/maintenance/rotateAllKeys.ts",
    "check-keys": "bun run scripts/maintenance/checkKeys.ts",
    "setup:tokenizers": "bun run scripts/maintenance/downloadTokenizers.ts",
    "//audit": "audit:clean runs bun audit --audit-level=high — only high/critical advisories block the pipeline",
    "audit:clean": "bun run scripts/maintenance/auditClean.ts",
    "validate:static": "bun run check && bun run lint && bun run check-locales && bun run check-schema && bun run audit:clean",
    "validate:lifecycle": "bun scripts/maintenance/validateLifecycle.ts",
    "vl-db": "bun run validate:lifecycle",
    "vl": "bun run validate:static"
  },
  "author": "Bredrumb",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1011.0",
    "@aws-sdk/client-secrets-manager": "^3.1011.0",
    "@brave/brave-search-mcp-server": "2.0.80",
    "@google-cloud/storage": "^7.19.0",
    "@google/genai": "^1.44.0",
    "@hono/node-server": "^1.19.13",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@mozilla/readability": "^0.6.0",
    "@oevortex/ddg_search": "1.3.0",
    "@openrouter/sdk": "0.1.27",
    "@smithery/api": "^0.56.0",
    "@types/bun": "^1.3.10",
    "@types/dotenv": "^8.2.3",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "axios": "^1.15.0",
    "bing-translate-api": "^4.2.0",
    "bun-types": "^1.3.10",
    "discord.js": "14.25.1",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.7.0",
    "ffmpeg-static": "^5.3.0",
    "gifuct-js": "^2.1.2",
    "google-translate-api-x": "^10.7.2",
    "gpt-tokenizer": "^3.4.0",
    "hono": "^4.12.14",
    "jszip": "^3.10.1",
    "libsodium-wrappers": "^0.8.2",
    "matrix-appservice-bridge": "^11.2.0",
    "minimatch": "^10.2.4",
    "minimist": "^1.2.8",
    "music-metadata": "^11.12.3",
    "pdf-parse": "1.1.4",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "profane-words": "^2.1.0",
    "sharp": "^0.34.5",
    "turndown": "^7.2.4",
    "undici": "^6.24.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/ffmpeg-static": "^5.1.0",
    "@types/jszip": "^3.4.1",
    "@types/pdf-parse": "^1.1.5",
    "pino-pretty": "^13.1.3",
    "ts-morph": "^28.0.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@aws-sdk/xml-builder>fast-xml-parser": "5.7.0",
    "body-parser": ">=2.2.1",
    "body-parser>qs": "6.14.2",
    "express-rate-limit": "8.2.2",
    "express>qs": "6.14.2",
    "jws": "^3.2.2",
    "lodash": "^4.18.1",
    "minimatch": ">=10.2.3",
    "qs": "6.14.2",
    "hono": "$hono",
    "@hono/node-server": "1.19.13",
    "undici": "^6.24.0",
    "brace-expansion": ">=5.0.5",
    "fast-xml-parser": ">=5.7.0",
    "postcss": ">=8.5.10",
    "ajv": "^8.18.0",
    "form-data": ">=2.5.4",
    "underscore": ">=1.12.1",
    "nedb": "npm:@seald-io/nedb@4.1.2",
    "tough-cookie": ">=4.1.3",
    "follow-redirects": ">=1.16.0",
    "protobufjs": "7.5.5"
  },
  "patchedDependencies": {
    "@aws-sdk/xml-builder@3.972.11": "patches/@aws-sdk%2Fxml-builder@3.972.11.patch",
    "@matrix-org/matrix-sdk-crypto-nodejs@0.4.0": "patches/@matrix-org%2Fmatrix-sdk-crypto-nodejs@0.4.0.patch",
    "@sapphire/shapeshift@4.0.0": "patches/@sapphire%2Fshapeshift@4.0.0.patch"
  }
}
