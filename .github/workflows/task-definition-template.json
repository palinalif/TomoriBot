{
	"family": "tomoribot-task",
	"networkMode": "awsvpc",
	"requiresCompatibilities": ["FARGATE"],
	"cpu": "256",
	"memory": "512",
	"executionRoleArn": "EXECUTION_ROLE_ARN_PLACEHOLDER",
	"taskRoleArn": "EXECUTION_ROLE_ARN_PLACEHOLDER",
	"containerDefinitions": [
		{
			"name": "tomoribot",
			"image": "IMAGE_URI_PLACEHOLDER",
			"essential": true,
			"environment": [
				{
					"name": "NODE_ENV",
					"value": "production"
				},
				{
					"name": "RUN_ENV",
					"value": "production"
				},
				{
					"name": "POSTGRES_HOST",
					"value": "RDS_ENDPOINT_PLACEHOLDER"
				},
				{
					"name": "POSTGRES_PORT",
					"value": "5432"
				},
				{
					"name": "POSTGRES_USER",
					"value": "postgres"
				},
				{
					"name": "POSTGRES_DB",
					"value": "tomoribot"
				}
			],
			"logConfiguration": {
				"logDriver": "awslogs",
				"options": {
					"awslogs-group": "/ecs/tomoribot",
					"awslogs-region": "REGION_PLACEHOLDER",
					"awslogs-stream-prefix": "ecs",
					"awslogs-create-group": "true"
				}
			}
		}
	]
}
