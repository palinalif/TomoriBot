# Required local setup values
# Copy this file to .env and fill in the placeholders.

# Discord Bot Configuration (Required)
DISCORD_TOKEN=your_discord_bot_token_here
# Make sure your Discord bot has the following Privileged Gateway Intents:
# GuildMembers, MessageContent, GuildPresences

# Security (Required)
CRYPTO_SECRET=your_32_character_crypto_secret_here

# Database Configuration (Required for local Bun setup)
# When using Docker Compose, only POSTGRES_PASSWORD is required because the rest is auto-configured.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password
POSTGRES_DB=tomodb

# Runtime Configuration (Default is development)
RUN_ENV=development

# Thinking / reasoning defaults for providers that accept numeric budgets
# Used for mapped Low / Medium / High thinking levels where supported.
THINKING_LEVEL_BUDGET_LOW_TOKENS=1024
THINKING_LEVEL_BUDGET_MEDIUM_TOKENS=4096
THINKING_LEVEL_BUDGET_HIGH_TOKENS=8192
