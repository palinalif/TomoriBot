# Discord Bot Configuration (Required)
DISCORD_TOKEN=your_discord_bot_token_here

# Security (Required)
CRYPTO_SECRET=your_32_character_crypto_secret_here

# Database Configuration (Required for local Bun setup)
# When using Docker Compose, only POSTGRES_PASSWORD is required (see docker-compose.yaml)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password
POSTGRES_DB=tomodb

# Bot Configuration (Optional)
DEFAULT_BOTNAME=Tomori
DEFAULT_BOTNAME_JP=ともり
BASE_TRIGGER_WORDS=tomori,tomo,トモリ,ともり
RUN_ENV=development

# Avatar Storage (Production Optional)
# Used when RUN_ENV=production to host stable persona avatars in S3/CloudFront
AVATAR_S3_BUCKET=
# Optional override for S3 region (defaults to AWS_REGION or us-east-1)
AVATAR_S3_REGION=
# Optional prefix for avatar objects inside the bucket
AVATAR_S3_PREFIX=avatars
# Optional public base URL (CloudFront domain). If unset, defaults to S3 public URL.
AVATAR_PUBLIC_BASE_URL=

# GitHub Release Fetching (Optional - used by /help updates)
# Repository in owner/repo format for fetching latest release notes via the public GitHub API
GITHUB_REPO=Bredrumb/TomoriBot
# Timeout in milliseconds for the GitHub API request (default: 10000)
GITHUB_API_TIMEOUT_MS=10000

# NovelAI Timeouts (Optional)
# Overall request timeout in milliseconds (default: 60000)
NOVELAI_REQUEST_TIMEOUT_MS=60000
# Per-read inactivity timeout for streaming — aborts if NAI stops sending data (default: 30000)
NOVELAI_STREAM_READ_TIMEOUT_MS=30000

# NovelAI Image Generation (Optional)
# Enable suggest-tags prompt resolution for /generate_image_nai (default: false).
# Keep this disabled while NovelAI's suggest-tags API is unstable.
NAI_IMAGE_ENABLE_TAG_RESOLUTION=false

# Memory Limits (Optional)
# These limits are enforced during memory creation AND during data export/import
# MAX_PERSONAL_MEMORIES: Maximum number of personal memories per user (default: 25, max: 1000)
# MAX_SERVER_MEMORIES: Maximum number of server-wide memories (default: 25, max: 1000)
# MAX_MEMORY_LENGTH: Maximum character length per individual memory (default: 256, max: 2000)
MAX_PERSONAL_MEMORIES=25
MAX_SERVER_MEMORIES=25
MAX_MEMORY_LENGTH=256
# MAX_PERSONAS_PER_SERVER: Maximum personas (main + alters) per server (default: 20, max: 200)
MAX_PERSONAS_PER_SERVER=20
MAX_SAMPLE_DIALOGUE_LENGTH=2000
MAX_ATTRIBUTE_LENGTH=2000
MAX_TRIGGER_WORDS=10
MAX_SAMPLE_DIALOGUES=10
MAX_ATTRIBUTES=10
# Document/RAG Limits (Optional)
MAX_DOCUMENT_SIZE_MB=4
MAX_DOCUMENT_TEXT_LENGTH=120000
DOCUMENT_CHUNK_SIZE=1000
DOCUMENT_CHUNK_OVERLAP=200
MAX_DOCUMENT_CHUNKS=150
MAX_DOCUMENTS_PER_SERVER=20
MAX_DOCUMENT_CHUNKS_PER_SERVER=1000
# Enable document RAG in non-production (production always enables it)
ACTIVATE_LOCAL_RAG=false
# Inline Document Reading (read_document tool) - limits for chat-time document extraction
CHAT_DOCUMENT_MAX_SIZE_MB=8
CHAT_DOCUMENT_MAX_TEXT_LENGTH=100000
# /teach history - Window size for LLM extraction (default: 40)
# Default fetch window is 80 messages (configurable per server via /config maxmsgfetch)
HISTORY_EXTRACTION_WINDOW_SIZE=40

# Rate Limiting (Optional)
# Maximum active messages (processing + queued) per user across all servers
MAX_USER_ACTIVE_MESSAGES=5
# Maximum active messages (processing + queued) per server across all channels
MAX_SERVER_ACTIVE_MESSAGES=6
# Maximum document upload operations per user per 24 hours
MAX_DOCUMENT_OPERATIONS_PER_DAY=20

# Command Cooldowns (Optional)
# All cooldown values are in milliseconds
# Default cooldown applied to commands without specific category cooldowns
DEFAULT_COMMAND_COOLDOWN=1600
# Cooldown for /config commands
COOLDOWN_CONFIG=3000
# Cooldown for /teach commands
COOLDOWN_TEACH=3000
# Cooldown for /data commands
COOLDOWN_DATA=3000
# Cooldown for /forget commands
COOLDOWN_FORGET=3000
# Cooldown for /persona commands
COOLDOWN_PERSONA=10000
# Cooldown for /server commands
COOLDOWN_SERVER=3000
# Cooldown for /personal commands
COOLDOWN_PERSONAL=3000

# Memory & Media Protection (Optional)
# Number of most recent messages that can contain full media (images, videos, GIFs)
MEDIA_CONTEXT_WINDOW=10
# Number of most recent messages that can contain GIFs (stricter than general media)
GIF_LIMIT=5
# Maximum size per individual GIF file in MB (for process_gif tool in development)
MAX_GIF_SIZE_MB=50
# Container memory limit in MB (set to match your deployment environment)
CONTAINER_MEMORY_LIMIT_MB=512
# Memory warning threshold as percentage (0.75 = 75%)
MEMORY_WARNING_THRESHOLD=0.75
# Memory critical threshold as percentage (0.85 = 85%)
MEMORY_CRITICAL_THRESHOLD=0.85
# Maximum fetch response size in MB (protects against downloading large webpages)
MAX_FETCH_SIZE_MB=5
# Memory monitor polling interval in milliseconds (how often to check memory status)
MEMORY_MONITOR_INTERVAL_MS=30000

# Reaction Context Enrichment (Optional)
# Include per-message reaction metadata in LLM context (emoji, counts, and reactor names when budget allows)
REACTION_CONTEXT_ENABLED=true
# Max reaction user-fetch API calls per generation turn (counts-only fallback after this budget is exhausted)
REACTION_CONTEXT_MAX_API_CALLS_PER_TURN=20
# Max distinct reaction types included per message (sorted by highest count first)
REACTION_CONTEXT_MAX_REACTIONS_PER_MESSAGE=4
# Max reactor identities fetched per reaction type
REACTION_CONTEXT_MAX_USERS_PER_REACTION=5

# Cache TTL Configuration (Optional)
# Time-to-live for in-memory caches in minutes. Lower values = fresher data but more DB queries.
# TomoriState cache: server config, personality, memories (default: 10 minutes)
TOMORI_STATE_CACHE_TTL_MINUTES=10
# User cache: user preferences, privacy level, personal memories (default: 30 minutes)
USER_CACHE_TTL_MINUTES=30
# Emoji/Sticker cache: server emoji and sticker lists (default: 10 minutes)
EMOJI_STICKER_CACHE_TTL_MINUTES=10
# Channel Whitelist cache: whitelist status and per-channel cooldown overrides (default: 5 minutes)
CHANNEL_WHITELIST_CACHE_TTL_MINUTES=5

# Short-Term Memory Configuration (Optional)
# Short-term memory stores recent conversations for cross-channel awareness
# Crude conversation TTL: How long to keep raw conversation history in hours (default: 2)
SHORT_TERM_MEMORY_TTL_HOURS=2
# Summary TTL: How long to keep AI-generated summaries in hours (default: 4, longer than crude)
SHORT_TERM_MEMORY_SUMMARY_TTL_HOURS=4
# Maximum character length for AI-generated summaries (default: 500)
SHORT_TERM_MEMORY_MAX_SUMMARY_LENGTH=500
# Minimum messages required before prompting AI to create summary (default: 6)
SHORT_TERM_MEMORY_MIN_MESSAGES_FOR_SUMMARY=6
# Maximum number of messages stored per channel in crude conversation history (default: 10)
SHORT_TERM_MEMORY_MAX_MESSAGES_PER_CHANNEL=10
# Maximum number of other-channel memories to show in context (excludes current channel, default: 3)
SHORT_TERM_MEMORY_MAX_OTHER_CHANNELS=3

# OpenRouter Configuration (Optional)
# Hard cap on max_tokens sent to OpenRouter, regardless of what the model reports.
# Prevents HTTP 402 errors on accounts with low daily credit limits (default: 8192)
OPENROUTER_MAX_OUTPUT_TOKENS=8192
# Safety factor for dynamic context-window output capping (default: 0.9)
# Lower values are more conservative; higher values reserve more output tokens.
OPENROUTER_OUTPUT_SAFETY_FACTOR=0.9
# Best-effort minimum output tokens for OpenRouter requests (default: 256)
# Applied only when estimated remaining context can still fit this floor.
OPENROUTER_MIN_OUTPUT_TOKENS=256
# On empty-response retries caused by finishReason="length", drop this many oldest
# dialogue history exchange pairs per retry attempt (default: 2).
OPENROUTER_LENGTH_EMPTY_RETRY_DROP_PAIRS=2

# /tool estimate cost Configuration (Optional)
# Estimated output token bands shown in /tool estimate cost for current-context mode
HELP_COST_EST_OUTPUT_SHORT=80
HELP_COST_EST_OUTPUT_TYPICAL=220
HELP_COST_EST_OUTPUT_LONG=500
# Reference Google pricing (USD per million tokens) used for Google live-cost math
HELP_COST_GOOGLE_INPUT_PRICE_PER_MILLION=0.3
HELP_COST_GOOGLE_OUTPUT_PRICE_PER_MILLION=2.5

# NovelAI GLM Configuration (Optional)
# Enable/disable internal reasoning (thinking) for GLM 4.6 (default: true)
# When enabled, the model can reason before responding (improves tool calling quality)
# When disabled, /nothink is appended to suppress reasoning (faster, but may degrade tool use)
NAI_GLM_THINKING_ENABLED=true
# Maximum consecutive tool failures before showing an error embed (NAI GLM only)
NAI_TOOL_FAILURE_RETRY_THRESHOLD=3
# Include "{char}:" prefix in GLM 4.6 assistant turns and append it as a generation prefill (default: true)
# When enabled (default): bot name is kept in sample dialogue + history turns (mirrors Google/OpenRouter format),
# and "{botName}:" is appended after <think></think> at generation time to steer persona voice.
# When disabled: bot name is stripped — <|assistant|> tag is the structural signal alone
# (legacy behaviour; may produce garbled name artifacts like "Tomo", "Tomorleasing").
NAI_GLM_CHAR_PREFIX_ENABLED=true
# Characters-per-token ratio used to estimate GLM 4.6 input token count from prompt length (default: 2.5)
# GLM 4.6 tokenizes at ~2.2–2.5 chars/token — much denser than the 4 chars/token assumed by the
# context truncator. This value drives the dynamic max_length cap in novelaiStreamAdapter.ts that
# prevents 400 "too much context" errors caused by formatting overhead (GLM role tags, tool guide, etc.)
# not measured during contextItem truncation. Lower = more conservative (more clamping, shorter replies).
NAI_GLM_CHARS_PER_TOKEN=2.5
# Hard context window ceiling (input + output tokens combined) for GLM 4.6 (default: 12288)
# Used together with NAI_GLM_CHARS_PER_TOKEN to compute the dynamic max_length safety cap.
# Should match the actual NovelAI API limit for GLM 4.6. Adjusting novelaiCapabilityCache.ts
# (contextLength: 8_192) separately compensates for estimation errors in the truncator.
NAI_GLM_CONTEXT_LIMIT=12288

# Kayra context limit — override or fallback for the subscription tier auto-detect.
# By default, TomoriBot calls GET /user/subscription and maps the tier number to a known limit:
#   Tier 1 (Tablet):  4096 tokens
#   Tier 2 (Scroll):  8192 tokens (fallback default)
#   Tier 3 (Opus):    8192 tokens
# If this env var is EXPLICITLY SET, it takes priority over the API lookup entirely
# (no subscription API call is made). Leave it unset to use the auto-detect.
# Uncomment and set only if auto-detect gives wrong results or you want to skip the API call:
#NAI_KAYRA_CONTEXT_LIMIT=8192
# Characters-per-token ratio for Kayra context estimation (default: 3.5)
# Kayra tokenizes at ~3.0–3.5 chars/token. Used to compute a corrected virtual contextLength
# so the truncator's 4 chars/token estimate doesn't overshoot the real tier limit.
# Lower = more conservative truncation; higher = less truncation.
NAI_KAYRA_CHARS_PER_TOKEN=3.5

# Emoji Repetition Penalty (Optional)
# Enable/disable emoji repetition penalty system (true or false)
# NOTE: Only counts custom server emojis (:name:), NOT Unicode emojis (😊, 👍)
EMOJI_PENALTY_ENABLED=true
# Number of recent bot messages to analyze for custom emoji usage
EMOJI_PENALTY_LOOKBACK=3
# Maximum total custom emojis allowed across lookback window (exceeding this triggers penalty)
EMOJI_PENALTY_THRESHOLD=1

# Unique Emoji Enforcement (Optional)
# Enable/disable unique emoji filtering (prevents same custom emoji in consecutive messages)
EMOJI_UNIQUE_ENABLED=true
# Number of recent bot messages to track for unique emoji enforcement
EMOJI_UNIQUE_LOOKBACK=6
# Minimum shared prefix length (after normalization) required to merge adjacent custom emojis
# Example: JoeCaught_1 + JoeCaught_2 merge when set to 3; unrelated emojis stay separate
EMOJI_RUN_PREFIX_LENGTH=3

# Monitoring Configuration (Optional - for Grafana)
GRAFANA_PASSWORD=admin

# Matrix Appservice Bridge (Optional — leave all blank to disable the bridge entirely)
# Each persona appears as its own virtual Matrix user (e.g., @_tomori_lilya:yourdomain.com).
# Requires a self-hosted homeserver (Conduit/Synapse) with appservice registration support.
#
# Setup Steps:
# Step 1: Create appservice-registration.yaml (see HOWTO.md or docs/matrix/) with hs_token + as_token
# Step 2: Register the yaml file with your homeserver (add path to conduit.toml, restart)
# Step 3: Fill in the variables below and restart TomoriBot
#
# Token roles:
#   MATRIX_ACCESS_TOKEN = as_token (TomoriBot → homeserver auth)
#   MATRIX_HS_TOKEN     = hs_token (homeserver → TomoriBot auth, verified on incoming events)
MATRIX_HOMESERVER_URL=          # e.g., http://localhost:8448 or https://matrix.yourdomain.com
MATRIX_ACCESS_TOKEN=            # Appservice token (as_token) from appservice-registration.yaml
MATRIX_BOT_USER_ID=             # e.g., @tomoribot:yourdomain.com
MATRIX_SERVER_NAME=             # Homeserver domain only, e.g., localhost or yourdomain.com
MATRIX_HS_TOKEN=                # Homeserver token (hs_token) from appservice-registration.yaml
# Optional callback URL embedded in appservice registration.
# Required when Matrix homeserver is on a different host/network than TomoriBot.
# Examples:
#   Local:   http://localhost:9993
#   Remote:  https://matrix-appservice.example.com (https required for non-localhost)
MATRIX_APPSERVICE_PUBLIC_URL=
# HTTP port TomoriBot listens on for incoming events pushed by the homeserver (default: 9993)
MATRIX_APPSERVICE_PORT=9993
# Cache TTL for channel↔room link DB lookups in minutes (default: 5)
MATRIX_LINK_CACHE_TTL_MINUTES=5
# Maximum attachment size in MB to relay in either direction (Matrix→Discord or Discord→Matrix)
# Files larger than this are replaced with a text notice (default: 8 MB)
MATRIX_MAX_ATTACHMENT_MB=8
# Timeout in milliseconds for Matrix media download/upload operations (default: 15000 ms)
MATRIX_MEDIA_TIMEOUT_MS=15000
# Maximum characters per relayed embed text message before chunking (default: 3500)
MATRIX_EMBED_CHUNK_MAX_CHARS=3500

# Random Trigger System
# Maximum number of random triggers allowed per server (default: 10)
RANDOM_TRIGGER_MAX_PER_SERVER=10

# Top.gg Integration (Optional — leave blank to disable server count reporting)
# Obtain your token from https://top.gg/bot/:yourbotid/dashboard/integrations
TOPGG_TOKEN=
