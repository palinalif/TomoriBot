# Discord Bot Configuration (Required)
DISCORD_TOKEN=your_discord_bot_token_here

# Security (Required)
CRYPTO_SECRET=your_32_character_crypto_secret_here

# Database Configuration (Required for local Bun setup)
# When using Docker Compose, only POSTGRES_PASSWORD is required (see docker-compose.yaml)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password
POSTGRES_DB=tomodb

# Bot Configuration (Optional)
DEFAULT_BOTNAME=Tomori
DEFAULT_BOTNAME_JP=ともり
BASE_TRIGGER_WORDS=tomori,tomo,トモリ,ともり
RUN_ENV=development

# How many messages to fetch from Discord channels whenever triggered (Optional)
MESSAGE_FETCH_LIMIT=80

# Memory Limits (Optional)
MAX_PERSONAL_MEMORIES=25
MAX_SERVER_MEMORIES=25
MAX_MEMORY_LENGTH=256
MAX_SAMPLE_DIALOGUE_LENGTH=2000
MAX_ATTRIBUTE_LENGTH=2000
MAX_TRIGGER_WORDS=10
MAX_SAMPLE_DIALOGUES=10
MAX_ATTRIBUTES=10

# Rate Limiting (Optional)
# Maximum active messages (processing + queued) per user across all servers
MAX_USER_ACTIVE_MESSAGES=5
# Maximum active messages (processing + queued) per server across all channels
MAX_SERVER_ACTIVE_MESSAGES=6

# Memory & Media Protection (Optional)
# Number of most recent messages that can contain full media (images, videos, GIFs)
MEDIA_CONTEXT_WINDOW=10
# Number of most recent messages that can contain GIFs (stricter than general media)
GIF_LIMIT=5
# Maximum size per individual GIF file in MB (for process_gif tool in development)
MAX_GIF_SIZE_MB=50
# Container memory limit in MB (set to match your deployment environment)
CONTAINER_MEMORY_LIMIT_MB=512
# Memory warning threshold as percentage (0.75 = 75%)
MEMORY_WARNING_THRESHOLD=0.75
# Memory critical threshold as percentage (0.85 = 85%)
MEMORY_CRITICAL_THRESHOLD=0.85
# Maximum fetch response size in MB (protects against downloading large webpages)
MAX_FETCH_SIZE_MB=5
# Memory monitor polling interval in milliseconds (how often to check memory status)
MEMORY_MONITOR_INTERVAL_MS=30000

# Cache TTL Configuration (Optional)
# Time-to-live for in-memory caches in minutes. Lower values = fresher data but more DB queries.
# TomoriState cache: server config, personality, memories (default: 10 minutes)
TOMORI_STATE_CACHE_TTL_MINUTES=10
# User cache: user preferences, privacy level, personal memories (default: 30 minutes)
USER_CACHE_TTL_MINUTES=30
# Emoji/Sticker cache: server emoji and sticker lists (default: 10 minutes)
EMOJI_STICKER_CACHE_TTL_MINUTES=10

# Emoji Repetition Penalty (Optional)
# Enable/disable emoji repetition penalty system (true or false)
# NOTE: Only counts custom server emojis (:name:), NOT Unicode emojis (😊, 👍)
EMOJI_PENALTY_ENABLED=true
# Number of recent bot messages to analyze for custom emoji usage
EMOJI_PENALTY_LOOKBACK=3
# Maximum total custom emojis allowed across lookback window (exceeding this triggers penalty)
EMOJI_PENALTY_THRESHOLD=1

# Unique Emoji Enforcement (Optional)
# Enable/disable unique emoji filtering (prevents same custom emoji in consecutive messages)
EMOJI_UNIQUE_ENABLED=true
# Number of recent bot messages to track for unique emoji enforcement
EMOJI_UNIQUE_LOOKBACK=6

# Monitoring Configuration (Optional - for Grafana)
GRAFANA_PASSWORD=admin