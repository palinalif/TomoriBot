# Copy to terraform.tfvars and replace placeholder values.
# This file is safe to commit; real terraform.tfvars should stay local.

digitalocean_token = "REPLACE_ME"

project_name = "tomoribot-matrix"
region       = "nyc3"

droplet_name = "tomoribot-matrix-hs"
droplet_size = "s-1vcpu-1gb"
droplet_image = "ubuntu-24-04-x64"

# Restrict SSH to known operator IPs in production.
ssh_ingress_cidrs = ["203.0.113.10/32"]

# Add one or more SSH key fingerprints/IDs from your DigitalOcean account.
ssh_key_fingerprints = ["REPLACE_WITH_FINGERPRINT"]

volume_name     = "tomoribot-matrix-data"
volume_size_gib = 25

# Optional: only if this zone is managed in DigitalOcean DNS.
domain_name        = "example.com"
matrix_record_name = "matrix"
